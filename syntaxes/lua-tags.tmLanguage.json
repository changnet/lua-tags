{
    "scopeName": "lua-tags-doc",
    "injectionSelector": "L:comment",
    "patterns": [
        {
            "include": "#doc-param-support"
        },
        {
            "include": "#doc-return-support"
        },
        {
            "include": "#doc-type-support"
        },
        {
            "include": "#doc-field-support"
        },
        {
            "include": "#doc-class-support"
        },
        {
            "include": "#doc-alias-support"
        }
    ],
    "repository": {
        "doc-param-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "variable.parameter.doc-variable"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@param)\\s+(\\w+)(?:\\s+([\\w\\[\\]<>(),:.]+))?"
        },
        "doc-return-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@return)\\s*([\\w\\[\\]<>(),:.]+)?"
        },
        "doc-type-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@type)\\s*([\\w\\[\\]<>(),:.]+)?"
        },
        "doc-field-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "variable.other.doc-field"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@field)\\s+(\\w+)(?:\\s+([\\w\\[\\]<>(),:.]+))?"
        },
        "doc-class-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@class)\\s+(\\w+)(?:\\s*:\\s*(\\w+))?"
        },
        "doc-alias-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@alias)\\s+(\\w+)(?:\\s+([\\w\\[\\]<>(),:.]+))?"
        }
    }
}
