{
    "scopeName": "lua-tags-doc",
    "injectionSelector": "L:comment",
    "patterns": [
        {
            "include": "#doc-param-support"
        },
        {
            "include": "#doc-return-support"
        },
        {
            "include": "#doc-type-support"
        },
        {
            "include": "#doc-field-support"
        },
        {
            "include": "#doc-class-support"
        },
        {
            "include": "#doc-alias-support"
        }
    ],
    "repository": {
        "doc-param-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "variable.parameter.doc-variable"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@param)\\s+([A-Za-z0-9_]+)(?:\\s+([A-Za-z_][A-Za-z0-9_\\[\\]<>(),:. ]*))?"
        },
        "doc-return-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@return)\\s*([A-Za-z_][A-Za-z0-9_\\[\\]<>(),:. ]*)?"
        },
        "doc-type-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@type)\\s*([A-Za-z_][A-Za-z0-9_\\[\\]<>(),:. ]*)?"
        },
        "doc-field-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "variable.other.doc-field"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@field)\\s+([A-Za-z0-9_]+)(?:\\s+([A-Za-z_][A-Za-z0-9_\\[\\]<>(),:. ]*))?"
        },
        "doc-class-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@class)\\s+([A-Za-z0-9_]+)(?:\\s*:\\s*([A-Za-z0-9_]+))?"
        },
        "doc-alias-support": {
            "captures": {
                "1": {
                    "name": "keyword.other.doc-tag"
                },
                "2": {
                    "name": "entity.name.type"
                },
                "3": {
                    "name": "entity.name.type"
                }
            },
            "match": "\\s*-?(@alias)\\s+([A-Za-z0-9_]+)(?:\\s+([A-Za-z_][A-Za-z0-9_\\[\\]<>(),:. ]*))?"
        }
    }
}
